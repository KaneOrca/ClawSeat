# Example batch config for non-interactive ClawSeat installs (B1).
#
# Drop this at `~/.agents/install-config.toml` (minus the .example
# suffix) to drive `resolve_auth_mode.py` without prompts. Useful for
# fresh-machine reproducible installs and CI smoke tests.
#
# Each [seats.<seat_id>] block sets auth_mode (required) and provider
# (required only for auth_mode="api"). Seats not listed here fall
# through to the interactive wizard.
#
# Six canonical auth-modes (tool=claude):
#   auth_mode="oauth_token"                        — choice 1
#   auth_mode="api",      provider="anthropic-console" — choice 2
#   auth_mode="api",      provider="minimax"       — choice 3
#   auth_mode="api",      provider="xcode-best"    — choice 4
#   auth_mode="ccr"                                — choice 5
#   auth_mode="oauth"                              — choice 6 (legacy, warns)

[seats.koder]
auth_mode = "oauth_token"

[seats.planner]
auth_mode = "oauth_token"

[seats.builder-1]
auth_mode = "oauth_token"

[seats.builder-2]
auth_mode = "api"
provider = "anthropic-console"

[seats.reviewer-1]
auth_mode = "ccr"

[seats.qa-1]
auth_mode = "api"
provider = "minimax"

[seats.memory]
auth_mode = "oauth_token"
