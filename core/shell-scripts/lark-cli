#!/usr/bin/env bash
# lark-cli wrapper for sandboxed seat runtimes.
#
# Problem: lark-cli stores user-identity auth tokens in macOS Keychain
# with service-name keys derived from $HOME. Seats that run with a
# sandboxed HOME (`~/.agent-runtime/identities/<tool>/<auth>/<seat>/home`)
# cannot resolve the operator's user token, even though the seat already
# symlinks `~/.lark-cli/` to the real-home copy. The config files are
# shared, but the Keychain lookup still points at the wrong namespace.
#
# Fix: transparently route lark-cli invocations so they see the
# operator's real HOME ($AGENT_HOME, exported by agent-launcher.sh at
# seat start). This wrapper is seeded into `$HOME/bin/lark-cli` via
# `seed_user_tool_dirs()`, and `$HOME/bin` is prepended to PATH — so
# `lark-cli ...` inside a seat "just works" against the operator's
# Keychain-backed auth state.
#
# Outside a seat (AGENT_HOME unset or equal to HOME), the wrapper is a
# pure pass-through.
#
# Source of truth: core/shell-scripts/lark-cli in CLAWSEAT_ROOT.
# Seeding: agent-launcher.sh::seed_user_tool_dirs().
# Contract: reported as Round-8 post-merge DX fix
# (sandboxed HOME + lark-cli Keychain lookup mismatch).

set -e

# Resolve the real lark-cli binary by excluding the wrapper's directory
# from PATH, then walking PATH entries looking for an executable named
# `lark-cli`. Falls back to canonical macOS install locations.
_resolve_real_lark_cli() {
  local wrapper_dir
  wrapper_dir="$(cd "$(dirname -- "${BASH_SOURCE[0]}")" 2>/dev/null && pwd -P)" || wrapper_dir=""
  # Also treat $HOME/bin as potentially pointing to this wrapper via symlink.
  local wrapper_symlink_dir="$HOME/bin"

  local p candidate=""
  local IFS=:
  for p in $PATH; do
    [[ -z "$p" ]] && continue
    [[ "$p" == "$wrapper_dir" ]] && continue
    [[ "$p" == "$wrapper_symlink_dir" ]] && continue
    if [[ -x "$p/lark-cli" && ! -L "$p/lark-cli" ]]; then
      candidate="$p/lark-cli"
      break
    fi
    # Honor lark-cli that is itself a symlink (e.g. /opt/homebrew/bin/lark-cli
    # -> ../lib/node_modules/...), as long as the target is not back to us.
    if [[ -L "$p/lark-cli" ]]; then
      local resolved
      resolved="$(readlink -f "$p/lark-cli" 2>/dev/null || true)"
      if [[ -n "$resolved" && "$resolved" != "${BASH_SOURCE[0]}" ]]; then
        candidate="$p/lark-cli"
        break
      fi
    fi
  done
  unset IFS

  if [[ -z "$candidate" ]]; then
    for fallback in /opt/homebrew/bin/lark-cli /usr/local/bin/lark-cli; do
      if [[ -e "$fallback" ]]; then
        candidate="$fallback"
        break
      fi
    done
  fi

  printf '%s\n' "$candidate"
}

_real_lark_cli="$(_resolve_real_lark_cli)"

if [[ -z "$_real_lark_cli" ]]; then
  cat >&2 <<'ERR'
lark-cli-wrapper: cannot locate real lark-cli binary.
Tried: PATH (excluding wrapper dir and $HOME/bin),
       /opt/homebrew/bin/lark-cli,
       /usr/local/bin/lark-cli.
Install via `brew install @larksuite/cli` or equivalent.
ERR
  exit 127
fi

# In a sandbox seat, AGENT_HOME holds the operator's real home; HOME
# points at the per-seat sandbox. Route HOME to AGENT_HOME so the
# Keychain lookup (keyed on HOME) hits the operator's tokens.
if [[ -n "${AGENT_HOME:-}" && "$HOME" != "$AGENT_HOME" ]]; then
  exec env HOME="$AGENT_HOME" "$_real_lark_cli" "$@"
fi

# Outside a seat — transparent pass-through.
exec "$_real_lark_cli" "$@"
